# Copy this file to terraform.tfvars (gitignored) for local overrides.
# CI/CD passes these as -var flags on `terraform apply`.
#
# Required for initial bootstrapping:
#   cp terraform.tfvars.example terraform.tfvars
#   # Edit terraform.tfvars with your values
#   terraform init
#   terraform apply

project_id     = "melo-f5756"
project_number = "888632552624"
region         = "us-central1"

# Image overrides — set by Cloud Build on each deploy.
# Leave as defaults on first apply (uses placeholder "hello" image).
# api_image = "us-central1-docker.pkg.dev/melo-f5756/mello/api:latest"
# web_image = "us-central1-docker.pkg.dev/melo-f5756/mello/web:latest"

# CORS — comma-separated list of allowed origins.
# In production this is the web Cloud Run URL (set after first apply).
# cors_origins = "https://mello-web-xxxx-uc.a.run.app"

# audio_url_ttl_seconds = 900  # 15 minutes (default)
