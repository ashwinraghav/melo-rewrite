# Copy to .env and fill in.
# On Cloud Run, set these as environment variables in the console.

PORT=8080
HOST=0.0.0.0
ENV=development

GCP_PROJECT_ID=melo-f5756
STORAGE_BUCKET=melo-f5756-stories
AUDIO_URL_TTL_SECONDS=900

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Local dev uses gcloud ADC automatically (gcloud auth application-default login).
# Only set GOOGLE_APPLICATION_CREDENTIALS if you need a specific service account.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
