# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real credentials.

# API backend URL
# Local dev: http://localhost:8080
# Production: set to Cloud Run API URL before building
NEXT_PUBLIC_API_URL=http://localhost:8080

# Firebase Web SDK config (non-secret — these are public identifiers)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCBH3p0XEB1OuYl03YX8W9f8jbU-jhrwVg
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=melo-f5756.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=melo-f5756
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=melo-f5756.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=888632552624
NEXT_PUBLIC_FIREBASE_APP_ID=1:888632552624:web:fd61ffda6ea81926fc5f75

# Set to "true" to route Firebase Auth through the local emulator
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
